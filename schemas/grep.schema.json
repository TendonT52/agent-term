{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-term/schemas/grep.schema.json",
  "title": "agent-term grep --json output",
  "description": "JSON envelope emitted by `agent-term grep --json`. Overlapping context windows (`--around N`) merge into single blocks. Line numbers are 1-based.",
  "type": "object",
  "additionalProperties": false,
  "required": ["hits", "blocks"],
  "properties": {
    "hits": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of matching lines across all blocks."
    },
    "blocks": {
      "type": "array",
      "items": { "$ref": "#/$defs/block" }
    }
  },
  "$defs": {
    "block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_line_no", "end_line_no", "matches", "lines"],
      "properties": {
        "start_line_no": {
          "type": "integer",
          "minimum": 1,
          "description": "First line in the block (1-based, inclusive)."
        },
        "end_line_no": {
          "type": "integer",
          "minimum": 1,
          "description": "End of the block (1-based, exclusive). Matches Python slice convention."
        },
        "matches": {
          "type": "array",
          "items": { "$ref": "#/$defs/match" }
        },
        "lines": {
          "type": "array",
          "items": { "$ref": "#/$defs/line" }
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line_no", "timestamp_ms"],
      "properties": {
        "line_no": { "type": "integer", "minimum": 1 },
        "timestamp_ms": {
          "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }],
          "description": "Wall-clock timestamp from the `[<ms>] ` prefix. Null on non-timestamped logs."
        }
      }
    },
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["line_no", "is_match", "content"],
      "properties": {
        "line_no": { "type": "integer", "minimum": 1 },
        "is_match": { "type": "boolean" },
        "content": {
          "type": "string",
          "description": "Line body, with trailing newline stripped. Timestamp prefix stripped unless --keep-timestamps."
        }
      }
    }
  }
}
